{
  "name": "yj-travel-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 18084 --strictPort",
    "build": "vue-tsc --noEmit && vite build --outDir dist/client && vite build --ssr src/entry-server.ts --outDir dist/server && node scripts/prerender.mjs && node scripts/promote-client-dist.mjs",
    "preview": "vite preview --host 127.0.0.1 --port 18084 --strictPort"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "vite": "^6.0.5",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vue-tsc": "^2.2.0"
  }
}
